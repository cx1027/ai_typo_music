# Backend env example
#
# Copy to `backend/.env` (same working directory where you run uvicorn),
# or export these variables in your shell.

# --- Core ---
ENV=dev
API_PREFIX=/api
CORS_ORIGINS=http://localhost:5173
JWT_SECRET=change_me

# --- Database / Redis ---
DATABASE_URL=postgresql+psycopg://aimusic:aimusic@localhost:5432/aimusic
REDIS_URL=redis://localhost:6379/0

# --- Music generation: Replicate (ACE-Step API) ---
# Get your token at: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# --- Image generation: HuggingFace (FLUX.1 Schnell) ---
# 1. Accept the model license at: https://huggingface.co/black-forest-labs/FLUX.1-schnell
# 2. Get your token at: https://huggingface.co/settings/tokens
HUGGINGFACE_HUB_TOKEN=

# --- LLM expansion (sample_query mode): Anthropic Claude ---
# Used for simple mode to expand natural-language queries into lyrics + metadata.
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Storage (local by default) ---
STORAGE_BACKEND=local  # local | s3
LOCAL_STORAGE_DIR=.data

# Optional S3/R2
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
S3_BUCKET=

# --- Security ---
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- WeChat (optional) ---
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# --- Share app URL ---
SHARE_APP_URL=
